.container{padding:24rpx;background:#f5f7fa;min-height:100vh}.card{background:#fff;border-radius:20rpx;padding:28rpx;box-shadow:0 8rpx 24rpx rgba(0,0,0,.05)}.title{font-size:38rpx;font-weight:700;color:#1f2329}.subtitle{font-size:24rpx;color:#667085;margin-top:10rpx;margin-bottom:26rpx}.form-item{margin-bottom:22rpx}.label{display:block;font-size:26rpx;color:#344054;margin-bottom:10rpx}.picker{background:#f9fafb;border:1rpx solid #d0d5dd;border-radius:12rpx;padding:22rpx;font-size:28rpx;color:#101828}.btn-row{display:flex;gap:20rpx;margin-top:30rpx}.btn-primary,.btn-default{flex:1;border-radius:14rpx;font-size:28rpx}.btn-primary{background:#1677ff;color:#fff}.btn-default{background:#eff4ff;color:#1677ff}.hint-box{margin-top:26rpx;padding:20rpx;border-radius:12rpx;background:#f8fafc;color:#475467;font-size:24rpx;word-break:break-all}