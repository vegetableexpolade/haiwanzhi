<view class="container">
  <view class="card">
    <view class="title">首次修改密码</view>
    <view class="subtitle">首次登录必须先修改密码，之后才可继续使用小程序。</view>
    <view class="form-item">
      <text class="label">新密码</text>
      <input class="input" password placeholder="请输入新密码（至少6位）" value="{{password}}" bindinput="onInput" data-key="password" />
    </view>
    <view class="form-item">
      <text class="label">确认密码</text>
      <input class="input" password placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onInput" data-key="confirmPassword" />
    </view>
    <view class="btn-row">
      <button class="btn-primary" bindtap="submit">保存并进入系统</button>
    </view>
  </view>
</view>
