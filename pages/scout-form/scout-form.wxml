<view class="container">
  <view class="card">
    <view class="title">现场踏勘-{{typeLabel}}</view>
    <view class="form-item">
      <text class="label">岸段序号</text>
      <view class="input disabled-box">{{segment.segmentNo}}</view>
    </view>

    <block wx:if="{{typeKey !== 'tidal'}}">
      <view class="form-item">
        <text class="label">一级类</text>
        <picker mode="selector" range="{{primaryOptions}}" value="{{primaryIndex}}" bindchange="onPrimaryChange">
          <view class="picker">{{form.primary || '请选择一级类'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">二级类</text>
        <picker mode="selector" range="{{secondaryOptions}}" value="{{secondaryIndex}}" bindchange="onSecondaryChange">
          <view class="picker">{{form.secondary || '请选择二级类'}}</view>
        </picker>
      </view>
    </block>

    <block wx:if="{{typeKey === 'tidal'}}">
      <view class="form-item">
        <text class="label">潮滩选择</text>
        <picker mode="selector" range="{{tidalZones}}" value="{{zoneIndex}}" bindchange="onZoneChange">
          <view class="picker">{{activeZone || '请选择高潮区/中潮区/低潮区'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">潮间带类型（当前：{{activeZone || '未选择'}}）</text>
        <view class="tag-grid">
          <view class="tag {{selectedZoneTypes[item] ? 'active' : ''}} {{!activeZone ? 'disabled' : ''}}" wx:for="{{tidalTypes}}" wx:key="*this" data-value="{{item}}" bindtap="toggleTidalType">{{item}}</view>
        </view>
      </view>
      <view class="form-item">
        <text class="label">已选结果</text>
        <view class="hint-box">{{tidalSummary || '尚未选择'}}</view>
      </view>
    </block>

    <view class="form-item">
      <text class="label">备注</text>
      <textarea class="textarea" value="{{form.remark}}" placeholder="请输入备注信息" bindinput="onRemarkInput" />
    </view>

    <view class="form-item">
      <text class="label">定位</text>
      <view class="btn-row">
        <button class="btn-default" bindtap="getLocation">获取定位</button>
        <button class="btn-default" bindtap="openMap">地图查看</button>
      </view>
      <view class="input">经度：{{form.longitude || '未获取'}}；纬度：{{form.latitude || '未获取'}}</view>
    </view>

    <view class="form-item">
      <text class="label">拍照（最多5张）</text>
      <view class="btn-row">
        <button class="btn-default" bindtap="choosePhoto">+ 拍照</button>
      </view>
      <view class="photo-grid">
        <view class="photo-item" wx:for="{{photos}}" wx:key="index">
          <image src="{{item.path || item.tempFileURL || item.fileID}}" mode="aspectFill"></image>
          <view class="photo-del" data-index="{{index}}" bindtap="deletePhoto">×</view>
        </view>
      </view>
      <view class="muted">每条工作记录文本与照片总量不超过10MB，超出时会自动压缩图片。</view>
    </view>

    <view class="btn-row">
      <button class="btn-primary" bindtap="saveData">保存</button>
      <button class="btn-default" bindtap="goBack">返回</button>
    </view>
  </view>
</view>
